service : {
  getBoard: () -> (vec nat) query;
  getCurrentPlayer: () -> (nat) query;
  getWinner: () -> (nat) query;
  getWinningPattern: () -> (vec nat) query;
  isGameOver: () -> (bool) query;
  makeMove: (nat) -> (variant {
                        err: text;
                        ok: bool;
                      });
  reset: () -> ();
}
